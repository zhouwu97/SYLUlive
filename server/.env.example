# JWT 密钥（必填，生产环境请设置至少32位的随机字符串）
JWT_SECRET=

# PostgreSQL 连接字符串
# 格式: host=localhost port=5432 user=用户名 password=密码 dbname=数据库名 sslmode=disable
DSN=host=127.0.0.1 port=5432 user=shenliyuan password=your_password dbname=shenliyuan sslmode=disable

# 文件上传目录
UPLOAD_DIR=./uploads

# 初始化系统超级管理员账号（必填）
SUPER_ADMIN_ID=admin
SUPER_ADMIN_PASSWORD=admin123

# ==================================
# 邮件服务配置 (SMTP)
# 用于发送注册验证码、接收用户 Bug 反馈等
# ==================================
# 邮件发送服务器地址 (例如 smtp.qq.com 或 smtp.163.com)
SMTP_HOST=
# 邮件发送服务器端口 (通常为 465 或 587)
SMTP_PORT=
# 发件人邮箱账号
SMTP_USER=
# 邮箱授权码 (请在邮箱设置中获取，注意不是登录密码)
SMTP_PASS=
# 邮件发件人标识 (通常与 SMTP_USER 保持一致即可)
SMTP_FROM=

# 用来接收用户 Bug 反馈的邮箱 (如果不填，默认发到 13514252317@163.com)
FEEDBACK_EMAIL_TO=
