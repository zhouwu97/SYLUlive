# JWT 密钥（必填，生产环境请设置至少32位的随机字符串）
JWT_SECRET=

# PostgreSQL 连接字符串
# 格式: host=localhost port=5432 user=用户名 password=密码 dbname=数据库名 sslmode=disable
DSN=host=127.0.0.1 port=5432 user=shenliyuan password=your_password dbname=shenliyuan sslmode=disable

# 文件上传目录
UPLOAD_DIR=./uploads

# 超级管理员默认密码（必填，生产环境请设置强密码）
SUPER_ADMIN_DEFAULT_PASSWORD=
