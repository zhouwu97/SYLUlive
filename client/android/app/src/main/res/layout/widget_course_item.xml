<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- 垂直指示条：RemoteViews 中不要在横向 LinearLayout 里使用 layout_height="match_parent" 的 View，否则极易崩溃 -->
    <!-- 改用 TextView 设置固定高度或者利用内容撑开 -->
    <TextView
        android:layout_width="3dp"
        android:layout_height="36dp"
        android:background="#6366F1"
        android:layout_marginEnd="8dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/course_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#1A1A2E"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/course_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#6366F1"
            android:maxLines="1" />
    </LinearLayout>

    <TextView
        android:id="@+id/course_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="11sp"
        android:textColor="#9CA3AF"
        android:maxLines="1"
        android:layout_marginStart="8dp" />
</LinearLayout>
